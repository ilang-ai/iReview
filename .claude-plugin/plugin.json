{
  "name": "ireview",
  "displayName": "iReview",
  "version": "0.1.0",
  "description": "Universal AI-to-AI code review. Any model reviews your code. Zero CLI installs. One JSON config.",
  "author": {
    "name": "I-Lang Protocol",
    "url": "https://github.com/ilang-ai/iReview"
  },
  "license": "MIT",
  "homepage": "https://github.com/ilang-ai/iReview",
  "repository": "https://github.com/ilang-ai/iReview",
  "userConfig": {
    "api_key": {
      "type": "string",
      "title": "Review API key",
      "description": "API key for OpenRouter, DeepSeek, OpenAI, or compatible provider",
      "sensitive": true,
      "required": false
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/load-config.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
